node_modules
# Keep environment variables out of version control
.env

/generated/prisma

# SQLite database file (regenerated via migrate/seed)
/dev.db

# 収集した生データ(gzip)。DB(snapshots.raw_path)からのみ参照される再生成不能データだが、
# 大容量になるためリポジトリには含めない
/data/raw

# PM2のログ出力
/logs

# Oracle VM用SSH鍵(dev-config経由でPC間同期)
/tokens

# VM側ledger.jsonのローカルキャッシュ(npm run ledger:syncで取得、正本はVM側)
/data/ledger.vm.json
